generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Candle {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  nome           String
  mensagem       String?
  comprador      String
  compradorEmail String?
  transactionId  String?  @unique
  status         String   @default("ATIVA")
  valor          Float
  dias           Int
  maxAltura      Int
  criadoEm       DateTime @default(now())

  // Interações do Memorial
  oracoes        Int      @default(0)
  amens          Int      @default(0)
  rosas          Int      @default(0)
  mensagens      SupportMessage[]

  // Índices compostos para as queries mais frequentes.
  // Antes destes índices, as queries faziam collection scan no MongoDB.
  //   - lista do mural: filtra por status e ordena por criadoEm desc
  //   - webhook: busca vela pendente por compradorEmail ordenada por criadoEm desc
  @@index([status, criadoEm])
  @@index([compradorEmail, status, criadoEm])
}

model SupportMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  candleId  String   @db.ObjectId
  nome      String
  mensagem  String
  criadoEm  DateTime @default(now())

  // Índice para ordenar mensagens por data dentro de uma vela.
  @@index([candleId, criadoEm])

  candle    Candle   @relation(fields: [candleId], references: [id], onDelete: Cascade)
}
