generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Candle {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  nome           String
  mensagem       String?
  comprador      String
  compradorEmail String?
  transactionId  String?  @unique
  status         String   @default("ATIVA")
  valor          Float
  dias           Int
  maxAltura      Int
  criadoEm       DateTime @default(now())

  // Interações do Memorial
  oracoes        Int      @default(0)
  amens          Int      @default(0)
  rosas          Int      @default(0)
  mensagens      SupportMessage[]
}

model SupportMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  candleId  String   @db.ObjectId
  nome      String
  mensagem  String
  criadoEm  DateTime @default(now())

  candle    Candle   @relation(fields: [candleId], references: [id], onDelete: Cascade)
}
