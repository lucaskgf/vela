generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Candle {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  mensagem  String?
  comprador String
  valor     Float
  dias      Int
  maxAltura Int
  criadoEm  DateTime @default(now())
}
